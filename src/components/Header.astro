---
import { Image } from "astro:assets";
// logo was downloaded as logo.webp
import logo from "../assets/logo.webp";

const links = [
    { name: "Home", href: "/" },
    { name: "Opere", href: "/opere" },
    { name: "Bio", href: "/biografia-luca-sanna" },
    { name: "Blog", href: "/blog-arte" }, // Or /blog/ depending on structure
    { name: "Contatti", href: "/contatti" },
];
---

<header
    class="w-full py-6 md:py-8 px-6 md:px-12 flex justify-between items-center bg-[#121212]/90 backdrop-blur-md fixed top-0 left-0 right-0 z-50 border-b border-white/5 transition-all duration-300"
>
    <a
        href="/"
        class="block w-40 md:w-48 opacity-90 hover:opacity-100 transition-opacity"
    >
        <Image src={logo} alt="Luca Sanna Logo" class="w-full h-auto" />
    </a>

    <nav
        class="hidden md:flex gap-10 text-gray-300 uppercase tracking-[0.2em] text-xs font-medium"
    >
        {
            links.map((link) => (
                <a
                    href={link.href}
                    class="hover:text-white transition-colors duration-300 py-1 border-b border-transparent hover:border-white/40"
                >
                    {link.name}
                </a>
            ))
        }
    </nav>

    <!-- Mobile Menu Button (Simple Implementation) -->
    <button
        id="mobile-menu-btn"
        class="md:hidden text-white focus:outline-none p-2"
        aria-label="Menu"
    >
        <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>
</header>
<div
    id="mobile-menu"
    class="hidden fixed inset-0 bg-[#0a0a0a] z-[60] flex flex-col items-center justify-center space-y-10 text-2xl font-light tracking-widest"
>
    {
        links.map((link) => (
            <a
                href={link.href}
                class="text-gray-300 hover:text-white transition-colors mobile-link"
            >
                {link.name}
            </a>
        ))
    }
    <button
        id="close-menu-btn"
        class="absolute top-6 right-6 text-gray-400 hover:text-white transition-colors p-2"
        aria-label="Chiudi Menu"
    >
        <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M6 18L18 6M6 6l12 12"></path>
        </svg>
    </button>
</div>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const closeBtn = document.getElementById("close-menu-btn");

    if (btn && menu && closeBtn) {
        btn.addEventListener("click", () => {
            menu.classList.remove("hidden");
        });
        closeBtn.addEventListener("click", () => {
            menu.classList.add("hidden");
        });
    }
</script>
