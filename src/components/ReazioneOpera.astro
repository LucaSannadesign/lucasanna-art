---
interface Props {
    operaSlug: string;
}

const { operaSlug } = Astro.props;
---

<section class="reazione-opera" data-reazione-opera data-opera-slug={operaSlug} aria-label="Reazione silenziosa all'opera">
    <p class="reazione-opera__prompt">Questa opera ti ha lasciato qualcosa?</p>

    <div class="reazione-opera__actions" role="group" aria-label="Seleziona una reazione simbolica">
        <button type="button" class="reazione-opera__symbol" data-reazione="risonanza" aria-label="Risonanza emotiva">●</button>
        <button type="button" class="reazione-opera__symbol" data-reazione="tensione" aria-label="Tensione o movimento">▲</button>
        <button type="button" class="reazione-opera__symbol" data-reazione="silenzio" aria-label="Silenzio o peso">■</button>
    </div>

    <p class="reazione-opera__feedback" aria-live="polite"></p>
</section>

<script is:inline>
    const STORAGE_KEY = "opere-reazioni";
    const AGGREGATE_ENDPOINT = "/.netlify/functions/reazioni";
    const REAZIONE_COPY = {
        risonanza: "Questa opera, per te, ha una risonanza.",
        tensione: "Questa opera, per te, è tensione.",
        silenzio: "Questa opera, per te, resta in silenzio.",
    };
    let aggregateEnabled = true;

    const readReazioni = () => {
        try {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return {};
            const parsed = JSON.parse(raw);
            return parsed && typeof parsed === "object" ? parsed : {};
        } catch {
            return {};
        }
    };

    const writeReazioni = (value) => {
        try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(value));
        } catch {
            // silent fail: nessun tracciamento server-side richiesto
        }
    };

    const sendAnonymousReaction = (slug, reazione) => {
        const isLocal = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1";
        const isNetlifyDev = window.location.port === "8888";
        if (!aggregateEnabled || (isLocal && !isNetlifyDev)) return;

        fetch(AGGREGATE_ENDPOINT, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "omit",
            keepalive: true,
            body: JSON.stringify({ slug, reazione }),
        })
            .then((response) => {
                if (!response.ok) aggregateEnabled = false;
            })
            .catch(() => {
                aggregateEnabled = false;
                // fire-and-forget: nessun impatto UX lato utente
        });
    };

    const initReazioneOpera = () => {
        document.querySelectorAll("[data-reazione-opera]").forEach((root) => {
            if (!(root instanceof HTMLElement) || root.dataset.bound === "true") return;
            root.dataset.bound = "true";

            const slug = root.dataset.operaSlug || "";
            if (!slug) return;

            const symbols = Array.from(root.querySelectorAll(".reazione-opera__symbol"));
            const feedback = root.querySelector(".reazione-opera__feedback");

            const paintSelection = (selected) => {
                root.classList.toggle("has-selection", Boolean(selected));

                symbols.forEach((symbol) => {
                    const active = symbol.getAttribute("data-reazione") === selected;
                    symbol.classList.toggle("is-active", active);
                    symbol.setAttribute("aria-pressed", active ? "true" : "false");
                });

                if (feedback) feedback.textContent = selected ? (REAZIONE_COPY[selected] || "") : "";
            };

            paintSelection(readReazioni()[slug]);

            symbols.forEach((symbol) => {
                symbol.addEventListener("click", () => {
                    const scelta = symbol.getAttribute("data-reazione") || "";
                    if (!scelta) return;

                    const reazioni = readReazioni();
                    const precedente = reazioni[slug] || "";
                    reazioni[slug] = scelta;
                    writeReazioni(reazioni);
                    paintSelection(scelta);

                    if (precedente !== scelta) {
                        sendAnonymousReaction(slug, scelta);
                    }

                    root.classList.remove("is-feedback");
                    requestAnimationFrame(() => root.classList.add("is-feedback"));
                });
            });
        });
    };

    initReazioneOpera();
    document.addEventListener("DOMContentLoaded", initReazioneOpera, { once: true });
    document.addEventListener("astro:page-load", initReazioneOpera);
</script>

<style>
    .reazione-opera {
        margin: 3.5rem auto 0;
        max-width: 32rem;
        text-align: center;
    }

    .reazione-opera__prompt {
        margin: 0 0 0.9rem;
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #9b9b9b;
    }

    .reazione-opera__actions {
        display: inline-flex;
        gap: 0.65rem;
    }

    .reazione-opera__symbol {
        border: 1px solid rgba(255, 255, 255, 0.22);
        background: transparent;
        color: #d7d7d7;
        opacity: 1;
        width: 2.1rem;
        height: 2.1rem;
        line-height: 1;
        font-size: 1rem;
        transition: transform 180ms ease, opacity 180ms ease, border-color 180ms ease, color 180ms ease;
    }

    .reazione-opera.has-selection .reazione-opera__symbol {
        opacity: 0.45;
    }

    .reazione-opera__symbol:hover,
    .reazione-opera__symbol:focus-visible,
    .reazione-opera__symbol.is-active {
        border-color: rgba(255, 255, 255, 0.62);
        color: #fff;
        opacity: 1;
        transform: scale(1.06);
        outline: none;
    }

    .reazione-opera__feedback {
        margin: 0.8rem 0 0;
        min-height: 1.1rem;
        font-size: 0.66rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #8b8b8b;
        opacity: 0;
        transition: opacity 240ms ease;
    }

    .reazione-opera.is-feedback .reazione-opera__feedback {
        opacity: 1;
    }
</style>