---
const { triggerId = "percorso-trigger" } = Astro.props;
---

<div class="text-center mb-12">
    <button
        id={triggerId}
        type="button"
        class="percorso-trigger inline-flex items-center justify-center border border-white/25 px-6 py-3 text-xs md:text-sm uppercase tracking-[0.18em] text-white transition hover:border-white/60 hover:bg-white/10"
    >
        Vivi un percorso curatoriale
    </button>
</div>