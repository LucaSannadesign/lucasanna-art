---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts: CollectionEntry<"posts">[] = (await getCollection("posts"))
    .sort(
        (a, b) =>
            new Date(b.data.date || 0).getTime() -
            new Date(a.data.date || 0).getTime(),
    )
    .filter((post) => post.slug !== "blog-arte"); // Filter out the placeholder if it still exists (though we will delete it)

const title = "Il Mondo Creativo di Luca Sanna: Arte, Tecnologie e Innovazioni";
const description =
    "Esplora il Luca Sanna Art Blog per scoprire creazioni artistiche uniche, ispirazioni creative e consigli pratici. Un punto di riferimento per appassionati di arte contemporanea, con approfondimenti su tecniche e materiali.";
---

<BaseLayout title={title} description={description} context="blog">
    <section class="max-w-6xl mx-auto px-4 py-12 md:py-20">
        <header class="mb-24 text-center">
            <h1
                class="text-5xl md:text-7xl font-heading font-normal mb-10 text-white uppercase tracking-[0.2em]"
            >
                Blog
            </h1>
            <p
                class="text-lg text-gray-400 max-w-2xl mx-auto font-light leading-relaxed"
            >
                {description}
            </p>
        </header>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-24"
        >
            {
                posts.map((post) => (
                    <a href={`/blog/${post.slug}`} class="block group">
                        <div class="aspect-[3/2] overflow-hidden bg-[#1a1a1a] mb-6 relative">
                            {post.data.featuredImage ? (
                                <img
                                    src={post.data.featuredImage}
                                    alt={post.data.title}
                                    class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
                                />
                            ) : (
                                <div class="w-full h-full bg-[#1a1a1a] flex items-center justify-center text-gray-600 font-light tracking-widest uppercase text-sm">
                                    No Image
                                </div>
                            )}
                        </div>
                        <div class="pr-4">
                            <div class="flex justify-between items-baseline mb-3">
                                <time
                                    datetime={new Date(
                                        post.data.date,
                                    ).toISOString()}
                                    class="text-xs text-gray-500 uppercase tracking-widest"
                                >
                                    {new Date(
                                        post.data.date,
                                    ).toLocaleDateString("it-IT", {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    })}
                                </time>
                            </div>
                            <h2 class="text-2xl font-heading text-white mb-3 leading-tight group-hover:text-gray-300 transition-colors">
                                {post.data.title}
                            </h2>
                            {post.data.description && (
                                <p class="text-sm text-gray-400 leading-relaxed line-clamp-3 font-light">
                                    {post.data.description}
                                </p>
                            )}
                        </div>
                    </a>
                ))
            }
        </div>
    </section>
</BaseLayout>
